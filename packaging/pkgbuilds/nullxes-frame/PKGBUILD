# Maintainer: NULLXES Systems Engineering <packagers@nullxes.os>
pkgname=nullxes-frame
pkgver=0.1.0
pkgrel=1
pkgdesc='NULLXES OS Wayland compositor (FRAME)'
arch=('x86_64')
url='https://github.com/nullxes/vendeta'
license=('MIT')
depends=(
  'glibc' 'gcc-libs' 'libinput' 'libxkbcommon' 'wayland'
  'mesa' 'systemd-libs' 'seatd'
  'pixman' 'cairo' 'pango'
)
makedepends=(
  'rust' 'cargo' 'pkgconf' 'clang' 'wayland-protocols'
  'pipewire' 'libinput' 'libxkbcommon' 'seatd' 'libdrm' 'mesa' 'libdisplay-info'
)
optdepends=(
  'xorg-xwayland: legacy X11 application support'
  'pipewire: audio backend'
  'networkmanager: connection management'
  'upower: battery indicator'
)
provides=('frame')
options=('!debug' '!lto')
source=("nullxes-frame-${pkgver}.tar.zst::file://${PWD}/source.tar.zst")
b2sums=('SKIP')

prepare() {
  export CARGO_HOME="${srcdir}/cargo-home"
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo fetch --locked --target "$CARCH-unknown-linux-gnu"

  # Arch ships libdisplay-info 0.3.x, while libdisplay-info-sys 0.2.x
  # hard-codes an upper bound (< 0.3.0) in build.rs. Relax this bound
  # for distro builds so pkg-config can resolve the installed system lib.
  local libdisplay_build_rs
  while IFS= read -r libdisplay_build_rs; do
    sed -i "s/libdisplay-info < 0.3.0/libdisplay-info < 0.4.0/g" "${libdisplay_build_rs}"
  done < <(find "${CARGO_HOME}/registry/src" -type f -path "*/libdisplay-info-sys-*/build.rs")
}

build() {
  export CARGO_HOME="${srcdir}/cargo-home"
  export RUSTFLAGS="-C codegen-units=1 -C debuginfo=0"
  export SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH:-$(date +%s)}"
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo build --release --locked --bin frame
}

check() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo test --release --locked --bin frame -- --nocapture
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 target/release/frame "${pkgdir}/usr/bin/frame"

  # Wayland session entry.
  install -Dm644 packaging/sessions/nullxes.desktop \
    "${pkgdir}/usr/share/wayland-sessions/nullxes.desktop"

  # systemd user unit (activated by graphical-session.target).
  install -Dm644 packaging/systemd/user/nullxes-frame.service \
    "${pkgdir}/usr/lib/systemd/user/nullxes-frame.service"

  # /etc skeleton.
  install -Dm644 /dev/stdin "${pkgdir}/etc/nullxes/frame.toml" <<'TOML'
# NULLXES FRAME runtime configuration.
# Override by copying this file to ~/.config/nullxes/frame.toml.

[compositor]
xwayland = true
target_fps = 0
vrr = true
lock_on_suspend = true

[input]
natural_scroll = true
tap_to_click = true
pointer_accel = 0.0
repeat_delay = 400
repeat_rate = 30
xkb_layout = ""
xkb_variant = ""
xkb_options = ""

[workspace]
count = 9
wrap = false

[idle]
dim_ms = 300000
lock_ms = 600000
suspend_ms = 1800000

[keybindings]
launcher_binary = "nullxes-launcher"
lock_binary = "nullxes-lock"
TOML

  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
}

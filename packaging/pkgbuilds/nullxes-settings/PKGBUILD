pkgname=nullxes-settings
pkgver=0.1.0
pkgrel=1
pkgdesc='NULLXES OS configuration GUI'
arch=('x86_64')
url='https://github.com/nullxes/vendeta'
license=('MIT')
depends=('glibc' 'wayland' 'libxkbcommon' 'nullxes-fonts')
makedepends=('rust' 'cargo' 'pkgconf' 'wayland-protocols')
options=('!debug' '!lto')
source=("nullxes-settings-${pkgver}.tar.zst::file://${PWD}/source.tar.zst")
b2sums=('SKIP')

build() {
  export CARGO_HOME="${srcdir}/cargo-home"
  export RUSTFLAGS="-C codegen-units=1 -C debuginfo=0"
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo build --release --locked --bin nullxes-settings
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  install -Dm755 target/release/nullxes-settings "${pkgdir}/usr/bin/nullxes-settings"
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/nullxes-settings.desktop" <<'EOF'
[Desktop Entry]
Name=NULLXES Settings
Comment=Configure NULLXES OS
Exec=/usr/bin/nullxes-settings
Type=Application
Categories=System;Settings;
Icon=preferences-system
StartupNotify=true
EOF
}

pkgname=nullxes-slate
pkgver=0.1.0
pkgrel=1
pkgdesc='NULLXES OS terminal emulator (SLATE)'
arch=('x86_64')
url='https://github.com/nullxes/vendeta'
license=('MIT')
depends=('glibc' 'wayland' 'libxkbcommon' 'nullxes-fonts')
makedepends=('rust' 'cargo' 'pkgconf' 'wayland-protocols')
options=('!debug' '!lto')
source=("nullxes-slate-${pkgver}.tar.zst::file://${PWD}/source.tar.zst")
b2sums=('SKIP')

build() {
  export CARGO_HOME="${srcdir}/cargo-home"
  export RUSTFLAGS="-C codegen-units=1 -C debuginfo=0"
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo build --release --frozen --bin nullxes-slate
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  install -Dm755 target/release/nullxes-slate "${pkgdir}/usr/bin/nullxes-slate"
  # .desktop entry so SLATE shows up in LAUNCHER.
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/nullxes-slate.desktop" <<'EOF'
[Desktop Entry]
Name=SLATE
Comment=NULLXES terminal
Exec=/usr/bin/nullxes-slate
Type=Application
Terminal=false
Icon=utilities-terminal
Categories=System;TerminalEmulator;
StartupNotify=true
EOF
}

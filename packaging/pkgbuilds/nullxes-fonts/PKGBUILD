pkgname=nullxes-fonts
pkgver=0.1.0
pkgrel=1
pkgdesc='NULLXES OS fonts (Inter + JetBrains Mono installed at /usr/share/fonts/nullxes)'
arch=('any')
url='https://github.com/nullxes/vendeta'
license=('OFL')
depends=('fontconfig')
source=(
  "https://github.com/rsms/inter/releases/download/v4.0/Inter-4.0.zip"
  "https://github.com/JetBrains/JetBrainsMono/releases/download/v2.304/JetBrainsMono-2.304.zip"
)
b2sums=('SKIP' 'SKIP')

package() {
  install -d "${pkgdir}/usr/share/fonts/nullxes"
  cp -p "${srcdir}"/Inter-4.0/extras/ttf/Inter-Variable.ttf       "${pkgdir}/usr/share/fonts/nullxes/" || true
  cp -p "${srcdir}"/Inter-4.0/extras/ttf/Inter-Regular.ttf        "${pkgdir}/usr/share/fonts/nullxes/" || true
  cp -p "${srcdir}"/Inter-4.0/extras/ttf/Inter-Medium.ttf         "${pkgdir}/usr/share/fonts/nullxes/" || true
  cp -p "${srcdir}"/JetBrainsMono-2.304/fonts/ttf/*.ttf           "${pkgdir}/usr/share/fonts/nullxes/" || true
}

pkgname=nullxes-notif
pkgver=0.1.0
pkgrel=1
pkgdesc='NULLXES OS notification daemon (org.freedesktop.Notifications)'
arch=('x86_64')
url='https://github.com/nullxes/vendeta'
license=('MIT')
depends=('glibc' 'wayland' 'dbus' 'nullxes-fonts')
makedepends=('rust' 'cargo' 'pkgconf' 'wayland-protocols')
options=('!debug' '!lto')
source=("nullxes-notif-${pkgver}.tar.zst::file://${PWD}/source.tar.zst")
b2sums=('SKIP')

build() {
  export CARGO_HOME="${srcdir}/cargo-home"
  export RUSTFLAGS="-C codegen-units=1 -C debuginfo=0"
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo build --release --locked --bin nullxes-notif
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  install -Dm755 target/release/nullxes-notif "${pkgdir}/usr/bin/nullxes-notif"
  install -Dm644 packaging/systemd/user/nullxes-notif.service \
    "${pkgdir}/usr/lib/systemd/user/nullxes-notif.service"
  # D-Bus service file.
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/dbus-1/services/org.freedesktop.Notifications.service" <<'EOF'
[D-BUS Service]
Name=org.freedesktop.Notifications
Exec=/usr/bin/nullxes-notif
SystemdService=nullxes-notif.service
EOF
}
